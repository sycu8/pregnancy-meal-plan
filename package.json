{
  "name": "bau-an-gi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test tests/e2e",
    "test:watch": "vitest",
    "preview:cloudflare": "opennextjs-cloudflare build && wrangler dev",
    "deploy:cloudflare": "opennextjs-cloudflare build && node scripts/wrangler-with-env.mjs deploy",
    "ingest:blog": "tsx scripts/ingest-blog.ts",
    "ingest:blog:auto": "tsx scripts/ingest-blog-auto.ts",
    "publish:blog:auto": "npm run ingest:blog:auto && tsx scripts/publish-queued-posts.ts && npm run sync:blog && npm run generate:blog:en && npm run sync:blog:en",
    "add:blog-seeds": "node --experimental-strip-types scripts/add-blog-seeds.ts",
    "add:hospital-blog-seeds": "node --experimental-strip-types scripts/add-hospital-blog-seeds.ts",
    "add:pharmacy-blog-seeds": "node --experimental-strip-types scripts/add-pharmacy-blog-seeds.ts",
    "crawl:blog:hospitals": "node scripts/discover-hospital-posts.mjs",
    "crawl:blog:pharmacy": "node scripts/discover-pharmacy-sources.mjs",
    "sync:blog": "node --experimental-strip-types scripts/sync-blog-manifest.ts",
    "sync:blog:en": "node --experimental-strip-types scripts/sync-blog-en-manifest.ts",
    "generate:blog:en": "node scripts/build-blog-en.mjs",
    "publish:blog": "npm run add:blog-seeds && npm run add:hospital-blog-seeds && npm run add:pharmacy-blog-seeds && npm run sync:blog",
    "publish:blog:en": "npm run generate:blog:en && npm run sync:blog:en",
    "mobile:install": "cd mobile && npm install",
    "mobile:sync": "cd mobile && npm run sync",
    "mobile:android": "cd mobile && npm run open:android",
    "mobile:ios": "cd mobile && npm run open:ios"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.11.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.6",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.45.0"
  }
}
